# === Required ===

# Clerk authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me

# PostgreSQL database (Neon recommended)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tool_provisioning

# Encryption key for credentials at rest (AES-256-GCM)
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=replace-with-base64-32-byte-key

# Upstash Redis (for rate limiting)
KV_REST_API_URL=https://your-redis.upstash.io
KV_REST_API_TOKEN=replace-with-upstash-token

# === Optional ===

# App URL (auto-detected on Vercel, set manually for self-hosting)
# APP_URL=https://your-domain.com

# Brandfetch API (tool logos in the catalog)
# NEXT_PUBLIC_BRANDFETCH_CLIENT_ID=replace-with-brandfetch-client-id

# AI model for setup guide generation and form drafting
# Requires Vercel AI Gateway (auto-enabled on Vercel) or direct provider key
# AI_DRAFT_MODEL=anthropic/claude-sonnet-4.6
